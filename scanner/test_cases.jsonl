{"id": "int_adv_brace", "category": "integration", "subcategory": "adversarial_scanner", "description": "Unclosed brace '{' detected by scanner", "input": "@triton.jit\ndef kernel():\n    x = {1: 2\n", "has_errors": true}
{"id": "int_adv_spaceship", "category": "integration", "subcategory": "adversarial_parser", "description": "Spaceship operator <=> is valid tokens (OP_LE + OP_GT), parser would reject", "input": "@triton.jit\ndef kernel():\n    x = a <=> b\n", "has_errors": false, "min_tokens": 1}
{"id": "int_adv_empty_decorator", "category": "integration", "subcategory": "adversarial_parser", "description": "Empty decorator @ is valid AT token, parser would reject", "input": "@\ndef kernel():\n    pass\n", "has_errors": false, "has_types": ["AT"]}
{"id": "int_adv_invalid_float", "category": "integration", "subcategory": "adversarial_parser", "description": "1.2.3 tokenizes as FLOAT_NUM(1.2) DOT NUMBER(3), parser would reject", "input": "@triton.jit\ndef kernel():\n    x = 1.2.3\n", "has_errors": false, "has_types": ["FLOAT_NUM", "DOT", "NUMBER"]}
{"id": "int_adv_double_colon", "category": "integration", "subcategory": "adversarial_parser", "description": ":: tokenizes as two COLON tokens, parser would reject", "input": "@triton.jit\ndef kernel():\n    x :: y\n", "has_errors": false, "has_types": ["COLON"]}
